.pdfs/
*.ply
*.splat
*.bin
*.spz

# Editor / OS
.DS_Store
.vscode/
.idea/

# Intermediate research artefacts (PDFs parse / S2 cited-by / arxiv lists)
scripts_refs/

# Secrets / tokens — never commit
*.pem
*.key
*token*
.env
.env.*

# Hermes cron scheduler artefacts (workdir redirected to repo root;
# these are scanning/upgrading job logs, not project data)
cron/
